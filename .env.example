# Clé API Google Gemini (gratuite sur https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# JID WhatsApp autorisé (whitelist stricte)
# Format : <indicatif><numero>@s.whatsapp.net (sans +, sans espaces)
WHATSAPP_OWNER=33612345678@s.whatsapp.net

# Clé API Anthropic pour Claude Code CLI
ANTHROPIC_API_KEY=sk-ant-...

# Racines de projets autorisées (OBLIGATOIRE — pas de défaut permissif)
# Tout chemin hors de ces racines sera REFUSÉ par sécurité.
# Sépare par virgule, chemins absolus uniquement.
ALLOWED_PROJECT_ROOTS=/workspaces,/opt/projects

# (optionnel) Chemin absolu vers le binaire Claude Code
# Si non défini, résolu depuis PATH au boot. Recommandé en prod : pin explicite.
# CLAUDE_BIN=/usr/local/bin/claude

# (optionnel) HOME isolé pour Claude Code (évite la lecture du ~/.claude/ user)
# Défaut : <projet>/.claude-runtime-home
# CLAUDE_HOME=/opt/whatsapp-agent/.claude-runtime-home
